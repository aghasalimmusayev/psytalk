<!DOCTYPE html>
<html lang="az">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Şifrə Sıfırlama</title>
</head>

<body style="margin:0; padding:0; background-color:#f0f4f8; font-family:Arial, sans-serif;">

    <table width="100%" cellpadding="0" cellspacing="0">
        <tr>
            <td align="center" style="padding: 40px 16px;">

                <table width="600" cellpadding="0" cellspacing="0"
                    style="background:#ffffff; border-radius:8px; overflow:hidden;">

                    <!-- Header -->
                    <tr>
                        <td style="background-color:#5b6af0; padding:32px 40px; text-align:center;">
                            <h1 style="margin:0; color:#ffffff; font-size:24px; letter-spacing:2px;">
                                PSY•TALK
                            </h1>
                        </td>
                    </tr>

                    <!-- Body -->
                    <tr>
                        <td style="padding:40px;">

                            <p style="font-size:18px; font-weight:bold; color:#1a202c; margin:0 0 16px;">
                                Salam, {{firstName}}!
                            </p>

                            <p style="font-size:15px; color:#4a5568; line-height:1.7; margin:0 0 24px;">
                                Hesabınız üçün şifrə sıfırlama sorğusu alındı.
                                Yeni şifrə təyin etmək üçün aşağıdakı linkə klikləyin:
                            </p>

                            <p style="margin:0 0 8px;">
                                <a href="{{resetUrl}}" style="color:#5b6af0; font-size:14px; word-break:break-all;">
                                    {{resetUrl}}
                                </a>
                            </p>

                            <p style="font-size:12px; color:#a0aec0; margin:24px 0 0;">
                                Bu link <strong>15 dəqiqə</strong> ərzində etibarlıdır.
                            </p>

                            <p style="font-size:12px; color:#a0aec0; margin:12px 0 0;">
                                Bu sorğunu siz göndərməmisinizsə, bu emaili nəzərə almayın.
                            </p>

                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td style="background-color:#1e1b4b; padding:24px 40px; text-align:center;">
                            <p style="margin:0; font-size:12px; color:rgba(255,255,255,0.5);">
                                © 2026 PSYTALK MMC. Bakı, Azərbaycan
                            </p>
                        </td>
                    </tr>

                </table>
            </td>
        </tr>
    </table>

</body>

</html>