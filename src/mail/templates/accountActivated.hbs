<!DOCTYPE html>
<html lang="az">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hesab Aktivləşdirildi</title>
</head>

<body style="margin:0; padding:0; background-color:#f0f4f8; font-family:Arial, sans-serif;">

    <table width="100%" cellpadding="0" cellspacing="0">
        <tr>
            <td align="center" style="padding: 40px 16px;">

                <table width="600" cellpadding="0" cellspacing="0"
                    style="background:#ffffff; border-radius:8px; overflow:hidden;">

                    <!-- Header -->
                    <tr>
                        <td style="background-color:#059669; padding:32px 40px; text-align:center;">
                            <h1 style="margin:0; color:#ffffff; font-size:24px; letter-spacing:2px;">
                                PSY•TALK
                            </h1>
                        </td>
                    </tr>

                    <!-- Body -->
                    <tr>
                        <td style="padding:40px;">

                            <p style="font-size:18px; font-weight:bold; color:#1a202c; margin:0 0 16px;">
                                Təbriklər, {{firstName}}! 🎉
                            </p>

                            <p style="font-size:15px; color:#4a5568; line-height:1.7; margin:0 0 24px;">
                                Hesabınız PSYTALK administratoru tərəfindən yoxlanıldı və aktivləşdirildi.
                                Artıq platforma üzərindən xidmətlərinizi təqdim edə bilərsiniz.
                            </p>

                            <p style="font-size:13px; color:#4a5568; line-height:1.6; margin:0;">
                                Platformaya keçid etmək üçün:
                                <a href="{{platformUrl}}" style="color:#059669;">{{platformUrl}}</a>
                            </p>

                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td style="background-color:#1e1b4b; padding:24px 40px; text-align:center;">
                            <p style="margin:0; font-size:12px; color:rgba(255,255,255,0.5);">
                                © 2026 PSYTALK MMC. Bakı, Azərbaycan
                            </p>
                        </td>
                    </tr>

                </table>
            </td>
        </tr>
    </table>

</body>

</html>